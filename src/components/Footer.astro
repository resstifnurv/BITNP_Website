---
// Footer 组件
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-section">
      <h3 class="footer-title">BITNP 网络技术协会</h3>
      <p class="footer-description">
        致力于推动校园网络技术发展，培养技术人才，服务师生。
      </p>
    </div>
    
    <div class="footer-section">
      <h4 class="footer-subtitle">快速链接</h4>
      <ul class="footer-links">
        <li><a href="/news">新闻动态</a></li>
        <li><a href="/blog">技术博客</a></li>
        <li><a href="/services">服务项目</a></li>
        <li><a href="https://github.com/BITNP" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      </ul>
    </div>
    
    <div class="footer-section">
      <h4 class="footer-subtitle">联系我们</h4>
      <ul class="footer-contact">
        <li>邮箱: contact@bitnp.org</li>
        <li>地址: 北京理工大学</li>
        <li>© 2024 BITNP 网络技术协会</li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p class="footer-copyright">
      © 2024 BITNP Network Technology Association. All rights reserved.
    </p>
  </div>
</footer>

<style>
  /* 使用全局 CSS 变量 */
  
  .footer {
    background-color: var(--footer-bg);
    color: var(--footer-text);
    border-top: 1px solid var(--border-color);
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  
  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  
  .footer-section {
    display: flex;
    flex-direction: column;
  }
  
  .footer-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--footer-text);
  }
  
  .footer-description {
    line-height: 1.6;
    color: var(--footer-text);
    opacity: 0.9;
  }
  
  .footer-subtitle {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--footer-text);
  }
  
  .footer-links,
  .footer-contact {
    list-style: none;
    padding: 0;
  }
  
  .footer-links li,
  .footer-contact li {
    margin-bottom: 0.75rem;
  }
  
  .footer-links a {
    color: var(--footer-text);
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: 0.9;
  }
  
  .footer-links a:hover {
    color: var(--primary-color);
    opacity: 1;
  }
  
  .footer-contact li {
    color: var(--footer-text);
    opacity: 0.9;
  }
  
  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 2rem;
    text-align: center;
  }
  
  .footer-copyright {
    color: var(--footer-text);
    opacity: 0.7;
    font-size: 0.9rem;
  }
  
  /* 响应式设计 */
  @media (max-width: 768px) {
    .footer-content {
      padding: 2rem 1.5rem;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .footer-bottom {
      padding: 1rem 1.5rem;
    }
  }
  
  @media (max-width: 576px) {
    .footer-content {
      padding: 1.5rem 1rem;
    }
    
    .footer-title {
      font-size: 1.3rem;
    }
    
    .footer-subtitle {
      font-size: 1rem;
    }
  }
</style>
